{
  "name": "shv",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "dev:seed": "tsx scripts/devLibrarySeed.ts seed",
    "dev:seed:reset": "tsx scripts/devLibrarySeed.ts reset",
    "showcase:seed": "tsx scripts/showcaseLibrarySeed.ts seed",
    "showcase:seed:reset": "tsx scripts/showcaseLibrarySeed.ts reset",
    "showcase:screenshots": "tsx scripts/captureReadmeScreenshots.ts",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "express": "^4.21.2",
    "mime-types": "^2.1.35",
    "playwright": "^1.50.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "uuid": "^11.0.5",
    "vite": "^6.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
