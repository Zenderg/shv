{
  "name": "shv",
  "version": "1.4.5",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "npm run build:extension && npm run build:web && npm run build:server",
    "build:extension": "vite build --config vite.extension.config.ts",
    "build:extension-preview": "vite build --config vite.extension-preview.config.ts",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "dev:seed": "tsx scripts/devLibrarySeed.ts seed",
    "dev:seed:reset": "tsx scripts/devLibrarySeed.ts reset",
    "showcase:seed": "tsx scripts/showcaseLibrarySeed.ts seed",
    "showcase:seed:reset": "tsx scripts/showcaseLibrarySeed.ts reset",
    "showcase:screenshots": "tsx scripts/captureReadmeScreenshots.ts",
    "preview:extension": "vite --config vite.extension-preview.config.ts",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@tanstack/react-query": "^5.101.2",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.9.3",
    "ipaddr.js": "^2.4.0",
    "mime-types": "^2.1.35",
    "playwright": "^1.50.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "undici": "^7.28.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/express": "^5.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "supertest": "^7.0.0",
    "svelte": "^5.56.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
