{
  "name": "shv",
  "version": "1.4.6",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "npm run build:extension && npm run build:web && npm run build:server",
    "build:extension": "vite build --config vite.extension.config.ts",
    "build:extension-preview": "vite build --config vite.extension-preview.config.ts",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "dev:seed": "tsx scripts/devLibrarySeed.ts seed",
    "dev:seed:reset": "tsx scripts/devLibrarySeed.ts reset",
    "showcase:seed": "tsx scripts/showcaseLibrarySeed.ts seed",
    "showcase:seed:reset": "tsx scripts/showcaseLibrarySeed.ts reset",
    "showcase:screenshots": "tsx scripts/captureReadmeScreenshots.ts",
    "preview:extension": "vite --config vite.extension-preview.config.ts",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@tanstack/react-query": "^5.101.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.10.0",
    "ipaddr.js": "^2.4.0",
    "mime-types": "^3.0.2",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "undici": "^8.7.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "supertest": "^7.2.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tsx": "^4.23.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
